{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.openclaw.ai/schemas/github-forge-pipeline/priority-mapping.json",
  "title": "Priority Field Mapping",
  "description": "Bidirectional mapping between GitHub priority labels and Forge Pipeline priority field",
  "version": "1.0.0",
  "mappings": {
    "github_labels_to_forge_priority": {
      "priority: critical": "critical",
      "priority: high": "high",
      "priority: medium": "medium",
      "priority: low": "low",
      "P0": "critical",
      "P1": "high",
      "P2": "medium",
      "P3": "low",
      "critical": "critical",
      "high priority": "high",
      "medium priority": "medium",
      "low priority": "low"
    },
    "forge_priority_to_github_labels": {
      "critical": "priority: critical",
      "high": "priority: high",
      "medium": "priority: medium",
      "low": "priority: low"
    }
  },
  "label_patterns": {
    "exact_match": ["priority: critical", "priority: high", "priority: medium", "priority: low"],
    "normalized_match": {
      "P0": "critical",
      "P1": "high",
      "P2": "medium",
      "P3": "low"
    },
    "case_insensitive": true,
    "strip_prefix": ["priority:", "priority", "priority-"]
  },
  "ownership": {
    "github_owns": false,
    "forge_pipeline_owns": false,
    "resolution": "last-modified wins; both systems have equal claim to priority"
  },
  "conflict_handling": {
    "both_modified": "last_modified_wins",
    "github_only": "sync_to_forge",
    "forge_only": "sync_to_github"
  },
  "default_priority": "medium",
  "notes": [
    "GitHub doesn't have a native priority field; uses labels instead",
    "Forge Pipeline has a dedicated priority field (low/medium/high/critical)",
    "Priority labels are bidirectional: sync both ways",
    "If multiple priority labels exist, use highest priority",
    "Default to 'medium' if no priority label found"
  ]
}