{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.openclaw.ai/schemas/github-forge-pipeline/label-mapping.json",
  "title": "Label/Tag Field Mapping",
  "description": "Bidirectional mapping between GitHub labels and Forge Pipeline tags",
  "version": "1.0.0",
  "mappings": {
    "github_to_forge": {
      "type: bug": "bug",
      "type: enhancement": "enhancement",
      "type: documentation": "docs",
      "type: feature": "feature",
      "bug": "bug",
      "enhancement": "enhancement",
      "documentation": "docs",
      "good first issue": "good-first-issue",
      "good-first-issue": "good-first-issue",
      "help wanted": "help-wanted",
      "help-wanted": "help-wanted",
      "question": "question",
      "wontfix": "wontfix",
      "duplicate": "duplicate",
      "stale": "stale",
      "status: blocked": "status:blocked",
      "status: in-progress": "status:in-progress",
      "status: todo": "status:todo",
      "status: done": "status:done"
    },
    "forge_to_github": {
      "bug": "type: bug",
      "enhancement": "type: enhancement",
      "docs": "type: documentation",
      "feature": "type: feature",
      "good-first-issue": "good first issue",
      "help-wanted": "help wanted",
      "question": "question",
      "wontfix": "wontfix",
      "duplicate": "duplicate",
      "stale": "stale",
      "status:blocked": "status: blocked",
      "status:in-progress": "status: in-progress",
      "status:todo": "status: todo",
      "status:done": "status: done"
    }
  },
  "preserve_prefix": {
    "source:": {
      "description": "Source tags are preserved as-is",
      "example": "source:forge-pipeline → source:forge-pipeline",
      "bidirectional": true
    },
    "project:": {
      "description": "Project tags are preserved as-is",
      "example": "project:display-forge → project:display-forge",
      "bidirectional": true
    }
  },
  "ignore_labels": {
    "github": ["stale", "wip", "do-not-merge"],
    "forge": ["archived", "legacy"]
  },
  "normalize_rules": {
    "case": "lowercase",
    "spaces": "replace with hyphens",
    "special_chars": "remove except hyphen and colon"
  },
  "conflict_handling": {
    "both_modified": "merge_union",
    "description": "Union both label/tag sets; don't remove unless explicitly deleted"
  },
  "ownership": {
    "github_owns": false,
    "forge_pipeline_owns": false,
    "resolution": "merge union of both sets"
  },
  "notes": [
    "Labels and tags are bidirectional and merged (not replaced)",
    "Source tags (source:*) are always preserved",
    "Project tags (project:*) are always preserved",
    "Priority labels handled separately in priority-mapping.json",
    "Status labels (status:*) mapped separately in status-mapping.json",
    "Ignore labels like 'stale' or 'wip' that don't need sync"
  ]
}